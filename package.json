{
  "name": "regression-sniffer",
  "version": "1.0.1",
  "description": "Loyal CLI tool that sniffs out any follow-up and revert commit of your cherry-picked commit",
  "main": "src/main.ts",
  "bin": "./dist/main.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "build": "esbuild ./src/main.js --bundle --outdir=dist --platform=node --target=node24.0.0 --packages=bundle",
    "format": "prettier --write '**/*.ts'",
    "format-check": "prettier --check '**/*.ts'",
    "test": "vitest run --coverage",
    "update-snapshots": "vitest run --update",
    "all": "yarn && yarn run build && yarn run format && yarn test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/redhat-plumbers-in-action/regression-sniffer-cli.git"
  },
  "keywords": [
    "cli",
    "regression-detection",
    "revert",
    "follow-up"
  ],
  "author": "jamacku@redhat.com",
  "license": "GPL-3.0+",
  "packageManager": "yarn@4.16.0",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@octokit/core": "^7.0.6",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/types": "^16.0.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "jira.js": "^5.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "0.6.1",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.8",
    "esbuild": "^0.28.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
